# Express MCP Server — environment variables
# Copy to .env and fill in your values.

# Local LLM endpoint (OpenAI-compatible API)
EXPRESS_LLM_ENDPOINT=http://localhost:8080/v1
EXPRESS_LLM_MODEL=your-multimodal-model

# Usagi Engine binary path (built from usagi-source/)
EXPRESS_USAGI_BIN=/home/monaghan/.build/express/usagi-source/target/release/usagi

# Usagi project workspace (where llm_output.lua lives)
EXPRESS_USAGI_WORKSPACE=/home/monaghan/.build/express/usagi-workspace

# DRM / framebuffer target
EXPRESS_FRAMEBUFFER=/dev/fb0
EXPRESS_DRM_CARD=/dev/dri/card0

# Screen capture method: fbgrab | fb0 | screenshot
EXPRESS_CAPTURE_METHOD=fbgrab

# Max self-heal passes before giving up
EXPRESS_MAX_HEAL_PASSES=3

# Render timeout in seconds (total tool call budget)
EXPRESS_RENDER_TIMEOUT=30
